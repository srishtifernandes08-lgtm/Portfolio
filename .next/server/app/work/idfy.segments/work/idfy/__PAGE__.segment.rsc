acking-tight text-[var(--foreground)] mb-3","children":"Focus Areas"}],"\n",["$","ul",null,{"className":"list-disc pl-6 mb-6 text-gray-700 space-y-2 marker:text-gray-400","children":["\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"Enterprise product design:"}]," Creating scalable, robust solutions capable of handling massive volumes of complex data."]}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"Designing for regulated industries:"}]," Navigating the strict compliance, security, and privacy constraints inherent to identity verification."]}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"Complex workflows:"}]," Synthesising fragmented, multi-persona processes into coherent, streamlined user interfaces."]}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"Large stakeholder ecosystems:"}]," Aligning business leaders, engineering teams, compliance officers, and users around a unified product vision."]}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"Cross-functional collaboration:"}]," Bridging the gap between technical constraints and user experience aspirations."]}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"Leading product direction:"}]," Setting the long-term design strategy and mentoring other designers."]}],"\n"]}]]}]]}],["$","div",null,{"className":"space-y-32","children":["$L4"]}]]}]]}]]}]}],"$L5"],["$L6","$L7"],"$L8"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"li2PQgQUDEc9dNzQVZxoH"}
4:["$","article","video-kyc",{"id":"video-kyc","className":"scroll-mt-32","children":[["$","div",null,{"className":"mb-8","children":[["$","span",null,{"className":"text-[var(--accent)] font-semibold uppercase tracking-widest text-sm","children":"Case Study"}],["$","h2",null,{"className":"text-4xl font-serif text-gray-900 mt-2 mb-8","children":"Video KYC"}]]}],["$","div",null,{"className":"prose prose-lg prose-gray max-w-none","children":[["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Business Context"}],"\n",["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Financial institutions in India were mandated by the RBI to implement Video Customer Identification Process (V-CIP) to facilitate remote onboarding during and after the pandemic. The existing physical verification process was slow, costly, and prone to drop-offs."}],"\n",["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Problem"}],"\n",["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Users were experiencing high drop-off rates during the video call due to poor network connectivity, confusing interface states, and unclear instructions on how to present their documents to the camera."}],"\n",["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Objectives"}],"\n",["$","ul",null,{"className":"list-disc pl-6 mb-6 text-gray-700 space-y-2 marker:text-gray-400","children":["\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Reduce drop-off rates by 30%."}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Ensure 100% compliance with RBI guidelines regarding live photo capture and liveness checks."}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Create an interface that guides low-digital-literacy users through a complex, high-friction process."}],"\n"]}],"\n",["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Constraints"}],"\n",["$","ul",null,{"className":"list-disc pl-6 mb-6 text-gray-700 space-y-2 marker:text-gray-400","children":["\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Strict regulatory requirements dictating specific user actions (e.g., reading a randomized code aloud)."}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Highly variable user network conditions and device capabilities across Tier 2 and Tier 3 cities."}],"\n"]}],"\n",["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"My Role"}],"\n",["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Lead Product Designer"}],"\n",["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Team"}],"\n",["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Product Manager, 2 Frontend Engineers, 1 Backend Engineer, Compliance Officer."}],"\n",["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Responsibilities"}],"\n",["$","ul",null,{"className":"list-disc pl-6 mb-6 text-gray-700 space-y-2 marker:text-gray-400","children":["\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"End-to-end UX/UI design."}],"\n","$L9","\n","$La","\n"]}],"\n","$Lb","\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10",