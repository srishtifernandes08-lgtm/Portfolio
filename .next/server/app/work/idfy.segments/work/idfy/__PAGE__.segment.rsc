9:["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"User research and usability testing."}]
a:["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Cross-functional alignment with legal and engineering teams."}]
b:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Research"}]
c:["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Conducted qualitative usability tests with 12 users representing the target demographic. We observed that users struggled most with camera permissions, audio feedback, and understanding the precise framing required for document capture."}]
d:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Insights"}]
e:["$","ul",null,{"className":"list-disc pl-6 mb-6 text-gray-700 space-y-2 marker:text-gray-400","children":["\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Users often did not realise when their microphone was muted."}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"The cognitive load of holding a document steady while looking at the camera was too high without clear, real-time visual feedback."}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Network degradation caused panic, leading users to prematurely abandon the call."}],"\n"]}]
f:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Information Architecture"}]
10:["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Streamlined the flow into three distinct phases: Pre-call Setup (Hardware Checks), Active Verification (Liveness & Document Capture), and Post-call Confirmation."}]
11:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"User Flows"}]
12:["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Designed a resilient flow that included \"graceful degradation\" states—if network quality dropped, the UI provided clear instructions on how to reconnect without losing progress."}]
13:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Wireframes"}]
14:["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Explored multiple layouts for the active call screen, testing the placement of the self-view versus the agent-view to ensure the user focused on the agent's instructions."}]
15:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Design Exploration"}]
16:["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"Iterated on the document capture overlay. Initially, we used a static bounding box, but shifted to a dynamic, animated guide that provided real-time feedback (e.g., \"Move closer\", \"Hold steady\")."}]
17:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Final Solution"}]
18:["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"A calm, guided interface that explicitly walked users through each step. We introduced a \"Network Health\" indicator before the call started to manage expectations, and used clear, unambiguous typography for on-screen instructions."}]
19:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Evidence Highlights"}]
