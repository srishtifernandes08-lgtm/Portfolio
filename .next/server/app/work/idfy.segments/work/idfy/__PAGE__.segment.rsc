1e:["$","ul",null,{"className":"list-disc pl-6 mb-6 text-gray-700 space-y-2 marker:text-gray-400","children":["\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Drop-off rates decreased by 42%."}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"Average verification time was reduced from 8 minutes to 4.5 minutes."}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":"The solution was adopted by 4 major banks within the first quarter of launch."}],"\n"]}]
1f:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Reflection"}]
20:["$","p",null,{"className":"text-lg md:text-xl leading-relaxed text-gray-700 max-w-[65ch] mb-6","children":"This project reinforced the importance of designing for worst-case scenarios. Assuming perfect network conditions is a luxury; robust design must account for friction and failure gracefully."}]
