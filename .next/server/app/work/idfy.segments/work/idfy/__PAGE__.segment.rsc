1b:["$","h3",null,{"className":"text-2xl md:text-3xl font-sans font-medium tracking-tight text-[var(--foreground)] mb-3","children":"Key Design Decisions"}]
1c:["$","ul",null,{"className":"list-disc pl-6 mb-6 text-gray-700 space-y-2 marker:text-gray-400","children":["\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"Pre-flight Checks:"}]," Mandating a hardware and network check ",["$","em",null,{"children":"before"}]," connecting to an agent drastically reduced in-call failures."]}],"\n",["$","li",null,{"className":"text-lg md:text-xl leading-relaxed max-w-[65ch]","children":[["$","strong",null,{"className":"font-semibold text-gray-900","children":"High-Contrast Overlays:"}]," Used high-contrast, bold typography for on-screen instructions to ensure readability even in low-light environments."]}],"\n"]}]
